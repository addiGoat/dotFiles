* {
  background-color: transparent;

  border: 0;
  margin: 0;
  padding: 0;
  spacing: 0;
}

configuration {
  font: env(ROFI_FONT, "JetBrainsMono Nerd Font Medium 12");

  drun {
    display-name: "";
  }

  run {
    display-name: "";
  }

  window {
    display-name: "";
  }
}

inputbar {
  children: [prompt, entry];
}

prompt {
  padding: 10px;
  text-color: #e0def4;
  enabled: false;
}
