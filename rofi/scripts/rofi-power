#!/bin/bash

confirm_action() {
	printf "%s\n" "No" "Yes" | rofi -dmenu -p "$1"
}

choice=$(printf "%s\n" "’ĆŻ Lock" "¾░Źā Logout" "¾░żä Suspend" "¾░£ē Reboot" "¾░Éź Shutdown" | rofi -dmenu)

case "$choice" in
	"’ĆŻ Lock")
		hyprlock
		;;
	"¾░Źā Logout")
		i3-msg exit
		;;
	"¾░żä Suspend")
		systemctl suspend
		;;
	"¾░£ē Reboot")
		confirm=$(confirm_action "Reboot?")
		case "$confirm" in
			Yes)
				systemctl reboot
				;;
			*)
				exit
				;;
		esac
		;;
	"¾░Éź Shutdown")
		confirm=$(confirm_action "Shutdown?")
		case "$confirm" in
			Yes)
				systemctl poweroff
				;;
			*)
				exit
				;;
		esac
		;;
	*)
		exit
		;;
esac


